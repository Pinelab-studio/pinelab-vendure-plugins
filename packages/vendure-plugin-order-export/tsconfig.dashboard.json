{
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "paths": {
      "@/gql": ["./src/gql/graphql.ts"],
      "@/vdb/*": ["../../node_modules/@vendure/dashboard/src/lib/*"],
      "@vendure/dashboard": [
        "../../node_modules/@vendure/dashboard/src/lib/index.ts"
      ],
      "virtual:*": [
        "../../node_modules/@vendure/dashboard/src/lib/virtual.d.ts"
      ],
      "virtual-*": [
        "../../node_modules/@vendure/dashboard/src/lib/virtual.d.ts"
      ]
    }
  },
  "include": [
    "src/gql/**/*.ts",
    "src/dashboard/**/*.tsx",
    "vite.*.*ts",
    "test/vite.config.mts"
  ]
}

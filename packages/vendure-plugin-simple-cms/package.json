{
  "name": "@pinelab/vendure-plugin-simple-cms",
  "version": "0.1.0",
  "description": "Vendure plugin for simple CMS content management",
  "keywords": [
    "vendure",
    "cms",
    "content management",
    "headless cms"
  ],
  "author": "Martijn van de Brug <martijn@pinelab.studio>",
  "homepage": "https://plugins.pinelab.studio/",
  "repository": "https://github.com/Pinelab-studio/pinelab-vendure-plugins",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "rimraf dist && yarn generate && tsc && copyfiles -u 1 'src/dashboard/**/*' dist/",
    "build:dashboard": "vite build --config ./vite.config.mts",
    "start": "nodemon --watch src --exec ts-node test/dev-server.ts",
    "serve": "nodemon --exec ts-node --swc test/dev-server.ts",
    "dev:dashboard": "vite --clearScreen false",
    "generate": "graphql-codegen",
    "test": "vitest run --bail 1",
    "lint": "eslint ."
  },
  "dependencies": {}
}

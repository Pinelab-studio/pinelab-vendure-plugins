---
import Footer from '../components/Footer.astro';
import Navigation from '../components/Navigation.astro';
import StructuredData from '../components/StructuredData.astro';
import {
  buildGraph,
  buildOrganization,
  buildWebSite,
} from '../utils/structured-data';
import '../styles/global.css';
import '@fontsource/ubuntu-mono';

interface Props {
  metaTitle: string;
  metaDescription: string;
  /** Extra JSON-LD nodes to merge into the page's @graph */
  structuredData?: Array<Record<string, unknown>>;
}
const { metaDescription, metaTitle, structuredData = [] } = Astro.props;
const ogImage = `${Astro.site}ogimage.png`;

let canonical = String(Astro.site);
if (Astro.url.pathname !== '/') {
  // Replace first slash
  const path = Astro.url.pathname.replace('/', '');
  // Append path to canonical
  canonical = `${Astro.site}${path}`;
}
const fullTitle = `${metaTitle} - Pinelab Plugins`;

// Always include Organization + WebSite, plus any per-page nodes
const graph = buildGraph([
  buildOrganization(),
  buildWebSite(),
  ...structuredData,
]);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/pinelab-sticker.webp" />
    <meta name="generator" content={Astro.generator} />
    <!-- meta tags -->
    <title>{fullTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={Astro.site} />
    <link rel="canonical" href={canonical} />
    <meta
      name="google-site-verification"
      content="JsngyXyEPIPlRY-5EbAXR9LZWwYi_OS3VUhd2WktSsg"
    />

    <StructuredData data={graph} />

    <script
      defer
      src="https://cloud.umami.is/script.js"
      data-website-id="f55cdd0f-cb0a-4879-89fd-f2dba97effe5"></script>
  </head>
  <body
    class="bg-base text-base-contrast flex min-h-screen flex-col p-8 text-lg"
  >
    <Navigation />

    <main class="mx-auto w-full max-w-7xl flex-1">
      <slot />
    </main>

    <Footer />
    <style is:global>
      html,
      body {
        margin: 0;
        width: 100%;
        scroll-behavior: smooth;
      }
    </style>
  </body>
</html>

---
import HeroSection from '../components/HeroSection.astro';
import Layout from '../layouts/Layout.astro';

import { getPlugins } from '../utils/plugins';
import {
  getPluginsContributors,
  type Contributor as ContributorType,
} from '../utils/contributors';
import Contributor from '../components/Contributor.astro';
import Cta from '../components/base/Cta.astro';

const plugins = await getPlugins();
const contributors = await getPluginsContributors();
---

<Layout
  metaTitle="Pinelab Vendure Plugins"
  metaDescription="Battle tested Vendure plugins, built by Pinelab.studio"
>
  <HeroSection />

  <section id="plugins" class="mt-16 mb-24 scroll-mt-24">
    <h2 class="mb-8 text-3xl font-bold lg:text-4xl">Plugins</h2>
    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        plugins.map((plugin) => (
          <div
            data-href={`/plugin/${plugin.slug}`}
            class="plugin-card flex cursor-pointer flex-col gap-3 rounded-lg border border-gray-800 p-6"
          >
            <div class="flex items-center gap-3">
              <img src={plugin.icon} class="size-10 rounded" alt="" />
              <span class="text-base-contrast font-semibold">
                {plugin.name}
              </span>
            </div>
            <p class="flex-1 text-sm text-gray-400">{plugin.description}</p>
            <div>
              <Cta
                href={`/plugin/${plugin.slug}`}
                variant="secondary"
                size="small"
              >
                Learn more
              </Cta>
            </div>
          </div>
        ))
      }
    </div>
  </section>

  {
    contributors.length > 0 && (
      <section class="mb-16">
        <h2 class="mb-2 text-center text-3xl font-bold lg:text-4xl">
          Contributors
        </h2>
        <p class="mb-12 text-center text-gray-400">
          Thanks to everyone who contributed to our plugins!
        </p>
        <div class="flex flex-wrap items-center justify-center gap-x-4 gap-y-4 sm:gap-x-12 sm:gap-y-8">
          {contributors.map((c: ContributorType) => (
            <a href={c.html_url} target="_blank">
              <Contributor
                name={c.login}
                image={c.avatar_url}
                contributions={c.contributions}
              />
            </a>
          ))}
        </div>
      </section>
    )
  }
</Layout>

<script>
  /** Make plugin cards clickable while letting inner links handle their own clicks. */
  document.querySelectorAll<HTMLElement>('.plugin-card').forEach((card) => {
    card.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a')) return; // inner Cta handles itself
      const href = card.dataset.href;
      if (href) window.location.href = href;
    });
  });
</script>

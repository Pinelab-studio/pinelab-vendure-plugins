---
import Layout from '../../layouts/Layout.astro';
import { getPlugins, type Plugin } from '../../utils/plugins';
import 'highlight.js/styles/github-dark-dimmed.css';

export async function getStaticPaths() {
  const plugins = await getPlugins();
  return plugins.map((p) => ({
    params: { pluginName: p.slug },
    props: { plugin: p },
  }));
}

const plugin: Plugin = Astro.props.plugin;
---

<Layout metaTitle={plugin.name} metaDescription={plugin.description}>
  <section class="mt-8 mb-24">
    <pre
      class="rounded"><code class="hljs language-shell"><span class="hljs-comment"># Install this plugin</span>
<span class="hljs-attr">npm</span> install {plugin.npmName}</code></pre>

    <!-- Changelog link -->
    <div class="mt-2 text-right">
      <a
        class="underline hover:opacity-80"
        href={`/plugin/${plugin.slug}/changelog`}
      >
        Changelog &rsaquo;
      </a>
    </div>

    <!-- Badges -->
    <div class="mt-2 flex flex-wrap items-center gap-2">
      <img
        src={`https://img.shields.io/badge/version-${plugin.version}-3DC685`}
      />
      {
        plugin.compatibility ? (
          <img
            src={`https://img.shields.io/badge/compatible with Vendure-${plugin.compatibility}-3DC685`}
          />
        ) : (
          <img src="https://img.shields.io/badge/dynamic/json.svg?url=https%3A%2F%2Fraw.githubusercontent.com%2FPinelab-studio%2Fpinelab-vendure-plugins%2Fmain%2Fpackage.json&query=$.devDependencies[%27@vendure/core%27]&colorB=green&label=Built%20on%20Vendure&color=%2317C1FF" />
        )
      }
      <img
        src={`https://img.shields.io/badge/dependencies-${plugin.nrOfDependencies}-3DC685`}
      />
    </div>

    <div
      class="prose prose-lg prose-invert blog-content !max-w-none mt-8"
      set:html={plugin.markdownContent}
    />

    <p class="mt-24">
      Need help? <a
        href="https://pinelab.studio/contact/"
        target="_blank"
        class="underline hover:opacity-80">Get In Touch</a
      >
    </p>
  </section>
</Layout>

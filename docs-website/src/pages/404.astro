---
import Layout from '../layouts/Layout.astro';
import Cta from '../components/base/Cta.astro';
---

<Layout metaTitle="404" metaDescription="Page not found">
  <section class="my-24 grid grid-cols-1 gap-8 lg:grid-cols-2 lg:items-center">
    <div>
      <p class="text-accent text-base font-semibold">404</p>
      <h1 class="mt-4 text-5xl font-bold lg:text-6xl">Page not found</h1>
      <p class="mt-6 text-lg text-gray-400">
        Sorry, we couldn't find the page you're looking for.
      </p>
      <div class="mt-10">
        <Cta href="/" variant="secondary">
          <span aria-hidden="true">&larr;</span> Back to home
        </Cta>
      </div>
    </div>
    <div class="hidden lg:block">
      <img
        src="/pinetree.webp"
        alt="Pine Tree not found"
        class="w-full max-w-md object-contain opacity-80"
      />
    </div>
  </section>
</Layout>
